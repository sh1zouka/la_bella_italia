@startuml
' ============================================================
' Use Case диаграмма — La Bella Italia
' ============================================================
' Скопировать в https://www.planttext.com для рендера

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam actorFontSize 14
skinparam useCaseFontSize 11
skinparam useCaseBorderThickness 1.5

left to right direction

title **Диаграмма вариантов использования (Use Case)**

' === Акторы ===
actor "Гость\n(не авторизован)" as Guest
actor "Клиент\n(зарегистрирован)" as User
actor "Администратор" as Admin

rectangle "Система доставки\n«La Bella Italia»" as System {
  
  ' === Варианты использования для всех ===
  usecase "UC-1\nПросмотр меню\n(все блюда)" as UC1
  usecase "UC-2\nПоиск и фильтрация\nблюд по категориям" as UC2

  ' === Варианты использования для гостя ===
  usecase "UC-3\nРегистрация\nнового аккаунта" as UC3
  usecase "UC-4\nВход в систему\n(авторизация)" as UC4

  ' === Варианты использования для клиента ===
  usecase "UC-5\nУправление корзиной\n(добавление/удаление)" as UC5
  usecase "UC-6\nОформление заказа\nс бонусной системой" as UC6
  usecase "UC-7\nПросмотр истории\nзаказов" as UC7
  usecase "UC-8\nПросмотр профиля\nи бонусов" as UC8
  usecase "UC-9\nОтслеживание статуса\nзаказа" as UC9

  ' === Варианты использования для администратора ===
  usecase "UC-10\nУправление меню\n(добавление/удаление)" as UC10
  usecase "UC-11\nУправление заказами\n(смена статуса)" as UC11
  usecase "UC-12\nУправление\nпользователями" as UC12
  usecase "UC-13\nПросмотр статистики\n(выручка, заказы)" as UC13
}

' === Связи акторов ===
Guest --> UC1
Guest --> UC2
Guest --> UC3
Guest --> UC4

User --> UC1
User --> UC2
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9

Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13

' === Отношения между вариантами ===
UC5 ..> UC6 : «include»
UC3 ..> UC4 : «extend»

legend bottom
  |= Актор |= Описание |
  | Гость | Неавторизованный пользователь |
  | Клиент | Авторизованный пользователь |
  | Администратор | Управляет системой |
endlegend

@enduml
