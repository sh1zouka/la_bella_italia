@startuml
' ============================================================
' DFD (Data Flow Diagram) — La Bella Italia
' ============================================================
' Скопировать в https://www.planttext.com для рендера

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12

title **DFD Level 0 — Контекстная диаграмма**

' === Внешние сущности ===
actor "Гость" as Guest0
actor "Клиент" as Client0
actor "Администратор" as Admin0

' === Центральный процесс ===
rectangle "Система доставки\n«La Bella Italia»" as System0

' === Хранилища ===
database "D1\nПользователи" as D1_0
database "D2\nМеню" as D2_0
database "D3\nЗаказы" as D3_0
database "D4\nКорзина\n(localStorage)" as D4_0

' === Потоки данных ===
Guest0 --> System0 : Регистрационные данные\n(имя, email, пароль, телефон)
Guest0 --> System0 : Учётные данные\n(email, пароль)
System0 --> Guest0 : Меню, результаты поиска,\nрезультат входа/регистрации

Client0 --> System0 : Данные корзины, доставки\nзапрос на списание бонусов
System0 --> Client0 : Меню, история заказов,\nпрофиль, результат заказа

Admin0 --> System0 : Управление меню, заказами
System0 --> Admin0 : Заказы, пользователи, статистика

System0 --> D1_0 : Чтение/запись
D1_0 --> System0 : Данные пользователей
System0 --> D2_0 : Чтение/запись
D2_0 --> System0 : Данные меню
System0 --> D3_0 : Чтение/запись
D3_0 --> System0 : Данные заказов
System0 <--> D4_0 : Чтение/запись корзины


' ============================================================
' DFD LEVEL 1
' ============================================================

newpage title **DFD Level 1 — Детализация процессов**

actor "Гость" as Guest
actor "Клиент" as Client
actor "Администратор" as Admin

rectangle "1.0\nАутентификация\nи профиль" as P1
rectangle "2.0\nУправление\nменю" as P2
rectangle "3.0\nУправление\nкорзиной" as P3
rectangle "4.0\nОформление и\nуправление\nзаказами" as P4
rectangle "5.0\nАдминистрирование\nсистемы" as P5

database "D1\nПользователи" as D1
database "D2\nМеню" as D2
database "D3\nЗаказы" as D3
database "D4\nКорзина\n(localStorage)" as D4
database "D5\nСессии\n(express-session)" as D5

' === 1.0 Аутентификация и профиль ===
Guest --> P1 : Регистрация (POST /api/register)\n{name, email, password, phone}
P1 --> Guest : {user: {id, name, bonusPoints: 100}}
P1 --> D1 : INSERT INTO users
D1 --> P1 : Данные пользователя

Guest --> P1 : Вход (POST /api/login)\n{email, password}
P1 --> Guest : {user: {...}}
P1 --> D1 : SELECT * FROM users WHERE email=?
P1 --> D5 : Создание сессии

Client --> P1 : Профиль (GET /api/me)
P1 --> Client : {user: {name, email, bonusPoints}}
P1 --> D5 : Проверка сессии

Client --> P1 : Выход (POST /api/logout)
P1 --> D5 : Уничтожение сессии

' === 2.0 Управление меню ===
Guest --> P2 : GET /api/menu
Client --> P2 : GET /api/menu?category=pizza
P2 --> Guest : [50 блюд с БЖУ]
P2 --> Client : Отфильтрованный список
P2 --> D2 : SELECT * FROM menu_items
D2 --> P2 : Массив блюд

Admin --> P2 : POST /api/admin/menu {name, price, ...}
P2 --> Admin : {id, name, ...}
P2 --> D2 : INSERT INTO menu_items
Admin --> P2 : DELETE /api/admin/menu/:id
P2 --> D2 : DELETE FROM menu_items

' === 3.0 Управление корзиной ===
Client --> P3 : addToCart(id, name, price)
Client --> P3 : removeFromCart(id)
Client --> P3 : updateQty(id, delta)
P3 --> Client : Обновлённая корзина
P3 --> D4 : localStorage.setItem('cart', ...)
D4 --> P3 : localStorage.getItem('cart')
P4 --> P3 : Запрос корзины для заказа
P3 --> P4 : [{id, name, price, qty, img}]

' === 4.0 Оформление и управление заказами ===
Client --> P4 : POST /api/orders\n{items, deliveryData, useBonuses}
P4 --> Client : {orderId, finalTotal, earnedBonuses}
P4 --> D3 : INSERT INTO orders
D3 --> P4 : Номер заказа
P4 --> D1 : UPDATE users SET bonusPoints
D1 --> P4 : Новый баланс

Client --> P4 : GET /api/orders/my
P4 --> D3 : SELECT * FROM orders WHERE userId=?
D3 --> P4 : Массив заказов
P4 --> Client : [{id, status, items, total, date}]

' === 5.0 Администрирование системы ===
Admin --> P5 : GET /api/admin/orders
P5 --> D3 : SELECT * FROM orders
D3 --> P5 : Все заказы
P5 --> Admin : Таблица заказов

Admin --> P5 : PATCH /api/admin/orders/:id {status}
P5 --> D3 : UPDATE orders SET status
D3 --> P5 : Подтверждение
P5 --> Admin : {ok: true}

Admin --> P5 : GET /api/admin/users
P5 --> D1 : SELECT * FROM users
D1 --> P5 : Все пользователи
P5 --> Admin : Таблица пользователей

Admin --> P5 : GET /api/admin/stats
P5 --> D3 : Агрегация: COUNT, SUM, AVG
D3 --> P5 : Статистические данные
P5 --> Admin : {totalOrders, revenue, avgOrder, ...}

' === Легенда ===
legend bottom
  |= Элемент |= Описание |
  | Процесс | Функция обработки данных |
  | Хранилище | Persistent storage (БД / localStorage) |
  | Актор | Внешняя сущность |
  | → Поток | Data flow / API-запрос |
endlegend

@enduml
