@startuml
' ============================================================
' Диаграмма активности — Оформление заказа
' ============================================================
' Скопировать в https://www.planttext.com для рендера

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12

title **Диаграмма активности оформления заказа**

start

:Пользователь открывает\nстраницу меню;

:Выбирает блюда\nи добавляет в корзину;

:Переходит на\nстраницу корзины;

:Корзина заполнена?;

if () then (Нет)
  :Вернуться к меню\nи выбрать блюда;
  stop
else (Да)
endif

:Вводит данные доставки\n(ФИО, телефон, адрес);

:Валидация полей\nна стороне клиента;

:Проверка валидации\nвсех полей?;

if () then (Ошибка)
  :Подсветить ошибки\nкрасным цветом;
  stop
else (OK)
endif

:Опционально:\nвключает списание бонусов;

:Отправляет запрос\nPOST /api/orders;

:Сервер проверяет\nавторизацию;

:Авторизация пройдена?;

if () then (401 — не авторизован)
  :Перенаправление\nна страницу входа;
  stop
else (OK)
endif

:Сервер рассчитывает\nитоговую сумму;
note right
  total = Σ(price × quantity)
  bonusDiscount = min(bonusPoints, total × 0.3)
  finalTotal = total - bonusDiscount
  earnedBonuses = finalTotal × 0.05
end note

:Создание заказа\nв базе данных;

:Заказ создан успешно?;

if () then (Ошибка БД)
  :Вернуть ошибку\n500;
  stop
else (Успех)
endif

:Обновление бонусов\nпользователя;

:Очистка корзины\nна клиенте;

:Отображение страницы\nуспеха #orderId;

:Администратор\nменяет статус заказа;

:Цикл обновления\nстатуса заказа;

while (Статус заказа)
  :Проверка текущего\nстатуса;
  
  if () then (confirmed)
    :→ preparing;
  elseif () then (preparing)
    :→ delivering;
  elseif () then (delivering)
    :→ done;
  elseif () then (done)
    :Заказ доставлен;
    break;
  elseif () then (cancelled)
    :Заказ отменён;
    break;
  endif
  
  :Пользователь просматривает\nстатус в профиле;
endwhile

:Пользователь получает\nзаказ;

stop

@enduml
