// ============================================================
// ER-диаграмма — La Bella Italia
// Формат DBML (Database Markup Language)
// Импортировать: https://dbdiagram.io  или draw.io
// ============================================================

Table users {
  id INTEGER [pk, increment, note: 'Первичный ключ']
  name VARCHAR(255) [not null, note: 'Имя пользователя']
  email VARCHAR(255) [not null, unique, note: 'Email (логин)']
  password VARCHAR(255) [not null, note: 'bcrypt-хэш пароля']
  phone VARCHAR(50) [default: '', note: 'Номер телефона']
  role VARCHAR(20) [default: 'user', note: 'Роль: user / admin']
  bonusPoints INTEGER [default: 100, note: 'Бонусные баллы (100 при регистрации)']
  createdAt TIMESTAMP [note: 'Дата регистрации']
}

Table menu_items {
  id INTEGER [pk, note: 'id блюда 1..50']
  category VARCHAR(50) [not null, note: 'Категория: pizza/pasta/starters/desserts/drinks']
  name VARCHAR(255) [not null, note: 'Название блюда']
  desc TEXT [default: '', note: 'Описание и состав']
  price INTEGER [not null, note: 'Цена в рублях']
  weight VARCHAR(20) [default: '', note: 'Вес/объём, напр. "400г"']
  img VARCHAR(50) [default: '🍽️', note: 'Эмодзи-иконка']
  photo VARCHAR(500) [default: '', note: 'URL фотографии']
  macros JSONB [default: '{}', note: 'КБЖУ: {kcal, protein, fat, carbs}']
  popular BOOLEAN [default: false, note: 'Флаг популярного блюда']
}

Table orders {
  id INTEGER [pk, increment, note: 'Первичный ключ']
  userId INTEGER [not null, ref: > users.id, note: 'Внешний ключ → users.id']
  items JSONB [default: '[]', note: 'Массив позиций заказа: [{menuItemId, name, price, quantity, img}]']
  total INTEGER [default: 0, note: 'Сумма до скидки']
  bonusDiscount INTEGER [default: 0, note: 'Скидка бонусными баллами']
  finalTotal INTEGER [default: 0, note: 'Итоговая сумма к оплате']
  earnedBonuses INTEGER [default: 0, note: 'Начислено бонусов за заказ']
  deliveryData JSONB [default: '{}', note: 'Данные доставки: {address, phone, comment}']
  status VARCHAR(20) [default: 'confirmed', note: 'Статус: confirmed/preparing/delivering/done/cancelled']
  createdAt TIMESTAMP [note: 'Дата и время заказа']
}

// ============================================================
// Расшифровка JSONB-структур
// ============================================================

// items (JSONB):
// [
//   {
//     "menuItemId": 1,     // id из menu_items
//     "name": "Маргарита",   // название на момент заказа
//     "price": 590,          // цена на момент заказа
//     "quantity": 2,         // количество
//     "img": "🍕"            // иконка
//   }
// ]

// deliveryData (JSONB):
// {
//   "address": "ул. Ленина, д. 10, кв. 5",
//   "phone": "+7 (999) 123-45-67",
//   "comment": "Позвонить за 5 минут"
// }

// macros (JSONB):
// {
//   "kcal": 820,
//   "protein": 34,
//   "fat": 28,
//   "carbs": 108
// }

// ============================================================
// Индексы
// ============================================================
INDEX idx_users_email ON users(email);
INDEX idx_orders_userId ON orders(userId);
INDEX idx_orders_status ON orders(status);
INDEX idx_menu_category ON menu_items(category);
INDEX idx_menu_popular ON menu_items(popular);
