@startuml
' ============================================================
' DFD (Data Flow Diagram) — La Bella Italia
' Диаграмма потоков данных
' Скопируйте в https://www.planttext.com
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 14
skinparam packageStyle rectangle
skinparam actorFontSize 16
skinparam rectangleFontSize 14
skinparam databaseFontSize 14
skinparam arrowFontSize 12
skinparam titleFontSize 18

' ============================================================
' DFD LEVEL 0 — КОНТЕКСТНАЯ ДИАГРАММА
' ============================================================

title **DFD Level 0 — Контекстная диаграмма**
caption Система доставки «La Bella Italia»

' === Внешние сущности ===
actor "Гость" as Guest0
actor "Клиент" as Client0
actor "Администратор" as Admin0

' === Система (единый процесс) ===
rectangle "0\nСистема доставки\nLa Bella Italia" as System0

' === Хранилища данных ===
database "D1\nПользователи" as D1_0
database "D2\nМеню" as D2_0
database "D3\nЗаказы" as D3_0
database "D4\nКорзина\n(localStorage)" as D4_0

' === Потоки данных Level 0 ===

' Гость → Система
Guest0 --> System0 : Данные регистрации (имя, email, пароль, телефон)
Guest0 --> System0 : Учётные данные (email, пароль)
System0 --> Guest0 : Меню, результаты поиска
System0 --> Guest0 : Результат регистрации/входа

' Клиент → Система
Client0 --> System0 : Данные корзины (id блюда, кол-во)
Client0 --> System0 : Данные доставки (имя, адрес, телефон)
Client0 --> System0 : Запрос на списание бонусов
System0 --> Client0 : Меню, история заказов, профиль
System0 --> Client0 : Результат заказа (номер, сумма, бонусы)

' Администратор → Система
Admin0 --> System0 : Управление меню (добавить/удалить)
Admin0 --> System0 : Смена статуса заказа
System0 --> Admin0 : Все заказы, пользователи, статистика

' Система ↔ Хранилища
System0 --> D1_0 : Чтение/запись данных пользователей
D1_0 --> System0 : Данные пользователей
System0 --> D2_0 : Чтение/запись меню
D2_0 --> System0 : Данные меню
System0 --> D3_0 : Чтение/запись заказов
D3_0 --> System0 : Данные заказов
System0 --> D4_0 : Чтение/запись корзины
D4_0 --> System0 : Данные корзины

' ============================================================
' DFD LEVEL 1 — ДЕТАЛИЗАЦИЯ ПРОЦЕССОВ
' ============================================================

newpage title **DFD Level 1 — Детализация процессов**
caption Декомпозиция системы доставки «La Bella Italia»

' === Внешние сущности ===
actor "Гость" as Guest
actor "Клиент" as Client
actor "Администратор" as Admin

' === Процессы ===
rectangle "1.0\nАутентификация\nи профиль" as P1
rectangle "2.0\nУправление\nменю" as P2
rectangle "3.0\nУправление\nкорзиной" as P3
rectangle "4.0\nОформление и\nуправление заказами" as P4
rectangle "5.0\nАдминистрирование\nсистемы" as P5

' === Хранилища данных ===
database "D1\nПользователи" as D1
database "D2\nМеню" as D2
database "D3\nЗаказы" as D3
database "D4\nКорзина\n(localStorage)" as D4
database "D5\nСессии\n(express-session)" as D5

' ===== ПОТОКИ ДАННЫХ =====

' === 1.0 Аутентификация и профиль ===
Guest --> P1 : Данные регистрации\n(имя, email, пароль, телефон)
Guest --> P1 : Учётные данные\n(email, пароль)
P1 --> Guest : Результат регистрации/входа
P1 --> D1 : Запись нового пользователя
P1 --> D1 : Проверка учётных данных
D1 --> P1 : Данные пользователя\n(id, name, email, role,\nbonusPoints)
P1 --> D5 : Создание сессии\n(Set-Cookie)
D5 --> P1 : Данные сессии\n(userId, роль)

Client --> P1 : Запрос профиля\n(GET /api/me)
P1 --> Client : Данные профиля\n(имя, email, бонусы, заказы)
P1 --> D1 : Обновление бонусов\nпосле заказа
D1 --> P1 : Обновлённые бонусы

Client --> P1 : Выход (POST /api/logout)
P1 --> D5 : Уничтожение сессии

=== 2.0 Управление меню ===
Guest --> P2 : Запрос меню\n(GET /api/menu)
Client --> P2 : Запрос с фильтром\n(категория, поиск)
P2 --> Guest : Список блюд\n(id, name, price, desc,\nweight, img, macros)
P2 --> Client : Отфильтрованный\nсписок блюд
P2 --> D2 : SELECT * FROM menu_items
D2 --> P2 : Массив блюд

Admin --> P2 : Добавление блюда\n(name, category, price,\ndesc, macros, popular)
Admin --> P2 : Удаление блюда\n(id)
P2 --> Admin : Результат операции
P2 --> D2 : INSERT / DELETE
D2 --> P2 : Подтверждение

=== 3.0 Управление корзиной ===
Client --> P3 : Добавить товар\n(id, name, price, qty+1)
Client --> P3 : Удалить товар (id)
Client --> P3 : Изменить кол-во\n(id, delta)
P3 --> Client : Обновлённая корзина
P3 --> D4 : Запись корзины
D4 --> P3 : Текущая корзина
P4 --> P3 : Запрос корзины\nдля оформления заказа
P3 --> P4 : Данные корзины\n(items: [{name, price, qty}])

=== 4.0 Оформление и управление заказами ===
Client --> P4 : Данные для заказа\n(items, deliveryData,\nuseBonuses)
' Валидация полей и расчёт бонусов выполняются внутри процесса 4.0
P4 --> D3 : INSERT INTO orders
D3 --> P4 : Номер заказа
P4 --> D1 : UPDATE bonusPoints
D1 --> P4 : Новый баланс бонусов
P4 --> Client : Результат заказа\n(orderId, finalTotal,\nearnedBonuses)

Client --> P4 : Запрос истории\n(GET /api/orders/my)
P4 --> D3 : SELECT * FROM orders\nWHERE userId = ?
D3 --> P4 : Массив заказов
P4 --> Client : История заказов\n(id, status, items, total, date)

=== 5.0 Администрирование системы ===
Admin --> P5 : Запрос всех заказов
P5 --> D3 : SELECT * FROM orders
D3 --> P5 : Все заказы
P5 --> Admin : Таблица заказов\n(клиент, адрес, состав,\nсумма, статус, дата)

Admin --> P5 : Смена статуса заказа\n(orderId, status)
P5 --> D3 : UPDATE orders SET status
D3 --> P5 : Подтверждение
P5 --> Admin : Статус обновлён

Admin --> P5 : Удаление заказа (orderId)
P5 --> D3 : DELETE FROM orders
D3 --> P5 : Подтверждение
P5 --> Admin : Заказ удалён

Admin --> P5 : Запрос пользователей
P5 --> D1 : SELECT * FROM users
D1 --> P5 : Все пользователи
P5 --> Admin : Таблица пользователей

Admin --> P5 : Запрос статистики
P5 --> D3 : Агрегация заказов\n(выручка, кол-во,\nстатусы)
D3 --> P5 : Статистические данные
P5 --> D1 : COUNT users
D1 --> P5 : Количество пользователей
P5 --> Admin : Статистика\n(заказы, выручка,\nсредний чек, пользователи)

' === Легенда ===
legend right
|= Элемент |= Описание |
| <size:10>◻ Процесс</size> | Функция обработки данных |
| <size:10>🗄 Хранилище</size> | Persistent storage (БД / localStorage) |
| <size:10>👤 Актор</size> | Внешняя сущность |
| <size:10>→ Поток</size> | Data flow / API-запрос |
endlegend

@enduml
