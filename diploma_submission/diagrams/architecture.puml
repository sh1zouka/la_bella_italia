@startuml
' ============================================================
' Диаграмма архитектуры — La Bella Italia
' Скопируйте в https://www.planttext.com
' ============================================================

skinparam componentStyle rectangle
skinparam backgroundColor #FEFEFE

' === Клиентская часть ===
package "Клиент (Frontend)" as Frontend {
  [HTML-страницы\n(index, menu, cart, auth,\nprofile, admin, 404)] as HTML
  [CSS Style] as CSS
  [JavaScript\n(app, auth, cart, db)] as JS
  component "Favicon" as FAV
}

' === Серверная часть ===
package "Сервер (Backend)" as Backend {
  [Express.js\n+ helmet, bcrypt,\nsession, rate-limit] as Express
  
  database "NeDB-совместимый\nслой абстракции" as NeDBWrapper {
    [find()\nfindOne()\ninsert()\nupdate()\nremove()\ncount()] as NeDBAPI
  }
  
  database "Sequelize ORM\n(User, MenuItem, Order)" as Sequelize {
    [Модели\n+ валидация\n+ JSONB] as Models
  }
}

' === База данных ===
database "PostgreSQL 16.x" as PG {
  [users] as T1
  [menu_items] as T2
  [orders] as T3
  [Индексы\nJSONB\nFOREIGN KEY] as PGFeatures
}

' === Связи ===
Frontend --> Backend : HTTP (JSON)
Backend --> Frontend : JSON Response

Express --> NeDBWrapper : db.users/menu/orders
NeDBWrapper --> Sequelize : sequelize.query
NeDBWrapper --> Sequelize : Model.findAll/create/update
Sequelize --> PG : TCP 5432
PG --> Sequelize : Результаты запросов

' === Внешние зависимости ===
cloud "Внешние сервисы" as External {
  [Google Fonts\n(шрифты)] as GF
  [bcryptjs\n(хэширование)] as BCRYPT
}

Frontend .> GF : Web Fonts API
Express .> BCRYPT : hashSync / compare

@enduml
